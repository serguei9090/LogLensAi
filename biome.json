{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignore": [
      ".vscode/**",
      ".agents/**",
      ".git/**",
      "node_modules/**",
      "dist/**",
      "src-tauri/target/**"
    ]
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noArrayIndexKey": "off",
        "noExplicitAny": "off"
      },
      "style": {
        "useBlockStatements": "error",
        "useFragmentSyntax": "error"
      },
      "a11y": {
        "noHeaderScope": "off",
        "useAltText": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "overrides": [
    {
      "include": ["src/styles/globals.css"],
      "css": {
        "parser": {
          "allowWrongLineComments": true
        }
      }
    }
  ]
}
