{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/.vscode",
      "!**/.agents",
      "!**/.git",
      "!**/node_modules",
      "!**/dist",
      "!**/src-tauri/target"
    ]
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noArrayIndexKey": "off",
        "noExplicitAny": "off"
      },
      "style": {
        "useBlockStatements": "error",
        "useFragmentSyntax": "error"
      },
      "a11y": {
        "noHeaderScope": "off",
        "useAltText": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "overrides": [
    {
      "includes": ["**/src/styles/globals.css"],
      "css": {
        "parser": {
          "allowWrongLineComments": true
        }
      }
    }
  ]
}
