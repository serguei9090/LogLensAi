diff a/sidecar/src/parser.py b/sidecar/src/parser.py	(rejected hunks)
@@ -23,3 +24,32 @@ class DrainParser:
 
     def get_clusters(self):
         return self.miner.drain.clusters
+
+    def apply_custom_config(self, log_line: str, config: dict) -> dict:
+        """
+        Applies a custom regex parser config to extract timestamp and level.
+        Returns a dict with 'timestamp' and 'level' if matched.
+        """
+        import re
+        result = {}
+        pattern = config.get("regex")
+        if not pattern:
+            return result
+        
+        try:
+            match = re.search(pattern, log_line)
+            if match:
+                groups = match.groupdict()
+                if "timestamp" in groups:
+                    result["timestamp"] = groups["timestamp"]
+                elif match.groups():
+                    result["timestamp"] = match.group(1)
+                else:
+                    result["timestamp"] = match.group(0)
+
+                if "level" in groups:
+                    result["level"] = groups["level"].upper()
+        except Exception:
+            pass
+
+        return result
